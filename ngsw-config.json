{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",

  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "updateMode": "prefetch",

      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },

    {
      "name": "assets",
      "installMode": "prefetch",
      "updateMode": "prefetch",

      "resources": {
        "files": [
          "/assets/**",
          "/icons/**",
          "/media/**",
          "/**/*.svg",
          "/**/*.jpg",
          "/**/*.jpeg",
          "/**/*.png",
          "/**/*.gif",
          "/**/*.webp",
          "/**/*.woff",
          "/**/*.woff2",
          "/**/*.ttf",
          "/**/*.otf"
        ]
      }
    }
  ],

  "dataGroups": [
    {
      "name": "google-fonts",

      "urls": [
        "https://fonts.googleapis.com/**",
        "https://fonts.gstatic.com/**"
      ],

      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 20,
        "maxAge": "30d",
        "timeout": "10s"
      }
    }
  ]
}
